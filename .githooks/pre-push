#!/bin/sh
# Pre-push: block protected branches and force pushes; run full gate.
set -e

branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo '')"

case "$branch" in
  main|master|prod|production|release/*)
    echo "ERROR: Direct pushes to '$branch' are blocked. Open a pull request." >&2
    exit 1
    ;;
esac

# Detect force push: remote has commits not in local history
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "ERROR: Force push on '$remote_ref' requires explicit human approval." >&2
      exit 1
    fi
  fi
done

npm run verify
